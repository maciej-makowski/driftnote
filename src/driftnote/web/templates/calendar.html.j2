{% extends "base.html.j2" %}
{% block title %}{{ year }}-{{ "%02d"|format(month) }} — Driftnote{% endblock %}
{% block content %}
<h1>{{ month_name }} {{ year }}</h1>
<nav class="month-nav">
  <a href="/?year={{ prev_year }}&month={{ prev_month }}">‹ prev</a>
  <a href="/?year={{ next_year }}&month={{ next_month }}">next ›</a>
</nav>
<table class="calendar">
  <thead><tr>
    {% for label in ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"] %}<th>{{ label }}</th>{% endfor %}
  </tr></thead>
  <tbody>
    {% for row in cells %}
      <tr>
      {% for c in row %}
        {%- set state = "has-entry" if c.emoji else "empty" -%}
        {%- if not c.in_month -%}
          {%- set td_class = "dim " ~ state -%}
        {%- elif c.date.isoformat() == today_iso -%}
          {%- set td_class = "today " ~ ("has-entry" if c.emoji else "today-empty") -%}
        {%- else -%}
          {%- set td_class = state -%}
        {%- endif %}
        <td class="{{ td_class }}">
          <a href="/entry/{{ c.date.isoformat() }}">
            <div class="dom">{{ c.day_of_month }}</div>
            <div class="emoji">{{ c.emoji or "·" }}</div>
          </a>
        </td>
      {% endfor %}
      </tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
